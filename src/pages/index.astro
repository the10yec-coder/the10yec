<script>
  // Events Slider Navigation (Infinite Scroll)
  document.addEventListener('DOMContentLoaded', () => {
    const slider = document.getElementById('eventsSlider');
    const scrollLeftBtn = document.getElementById('scrollLeft');
    const scrollRightBtn = document.getElementById('scrollRight');

    if (slider && scrollLeftBtn && scrollRightBtn) {
      let isTransitioning = false;
      
      // Calculate scroll amount based on card width + gap
      // The CSS defines flex basis and minimum width, we'll measure actual card width
      const getScrollAmount = () => {
        const firstCard = slider.querySelector('.event-card');
        if (!firstCard) return 380;
        
        // Include gap in calculation (gap is 2rem = ~32px)
        const style = window.getComputedStyle(slider);
        const gap = parseInt(style.gap) || 32;
        return firstCard.clientWidth + gap;
      };

      scrollLeftBtn.addEventListener('click', () => {
        if (isTransitioning) return;
        
        const scrollAmount = getScrollAmount();
        
        // If at the very beginning, smoothly scroll to end then snap
        if (slider.scrollLeft <= 10) {
          isTransitioning = true;
          // Move the last element to the beginning
          const lastChild = slider.lastElementChild;
          if (lastChild) {
            // Momentarily disable scroll snap and smooth behavior
            slider.style.scrollBehavior = 'auto';
            slider.style.scrollSnapType = 'none';
            
            // Move item
            slider.prepend(lastChild);
            
            // Adjust scroll position so it feels like we haven't moved
            slider.scrollLeft += scrollAmount;
            
            // Re-enable smooth scroll and actually animate
            requestAnimationFrame(() => {
              slider.style.scrollBehavior = 'smooth';
              slider.style.scrollSnapType = 'x mandatory';
              slider.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
              
              setTimeout(() => { isTransitioning = false; }, 400);
            });
          } else {
             isTransitioning = false;
          }
        } else {
          slider.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
        }
      });

      scrollRightBtn.addEventListener('click', () => {
        if (isTransitioning) return;

        const scrollAmount = getScrollAmount();
        
        // If at the very end
        if (Math.ceil(slider.scrollLeft + slider.clientWidth) >= slider.scrollWidth - 10) {
          isTransitioning = true;
          
          // Move the first element to the end
          const firstChild = slider.firstElementChild;
          if (firstChild) {
            slider.style.scrollBehavior = 'auto';
            slider.style.scrollSnapType = 'none';
            
            slider.append(firstChild);
            
            slider.scrollLeft -= scrollAmount;
            
            requestAnimationFrame(() => {
              slider.style.scrollBehavior = 'smooth';
              slider.style.scrollSnapType = 'x mandatory';
              slider.scrollBy({ left: scrollAmount, behavior: 'smooth' });
              
              setTimeout(() => { isTransitioning = false; }, 400);
            });
          } else {
            isTransitioning = false;
          }
        } else {
          slider.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        }
      });
      
      // Optional: Hide buttons if not enough content to scroll initially
      // But since we are infinite, we generally want to keep them if there are > 1 cards
      const checkScrollable = () => {
          if (slider.children.length <= 1) {
              scrollLeftBtn.style.display = 'none';
              scrollRightBtn.style.display = 'none';
          } else {
              scrollLeftBtn.style.display = 'flex';
              scrollRightBtn.style.display = 'flex';
          }
      };
      
      checkScrollable();
      // Use ResizeObserver for more robust width checking instead of just window resize
      new ResizeObserver(checkScrollable).observe(slider);
    }
  });
</script>

