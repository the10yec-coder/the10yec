---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProgramHero from '../../components/ProgramHero.astro';
import { Image } from 'astro:assets';
import aiCyberLabImage from '../../assets/images/ai-cyber-lab.png';
---

<BaseLayout title="Technology & Innovation - The10YEC Youth Excellence Center">
  <ProgramHero 
    title="Innovating the Future" 
    subtitle="Preparing youth for the future with hands-on experiences in cutting-edge technologies, robotics, AI, and startup acceleration."
    label="TECHNOLOGY"
    gradient="linear-gradient(135deg, var(--blue) 0%, #1565C0 100%)"
  />

  <!-- Overview Section -->
  <section class="section">
    <div class="container">
      <div class="two-col-layout">
        <div class="content-col">
          <h2 id="robotics">Robotics & Engineering</h2>
          <p>
            Hands-on engineering and programming experience. Our robotics program introduces 
            students to the fundamentals of mechanics, electronics, and software development, 
            allowing them to bring their ideas to life through physical builds.
          </p>
          <div class="yoga-sutra">
            <p>"The best way to predict the future is to invent it."</p>
          </div>
        </div>
        <div class="visual-col">
          <div class="feature-box">
            <div class="feature-icon">🤖</div>
            <h3>What We Cover</h3>
            <ul class="limbs-list">
              <li>Mechanical Design & Assembly</li>
              <li>Sensor Integration</li>
              <li>Microcontroller Programming</li>
              <li>AI in Robotics</li>
              <li>Competitive Problem Solving</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Innovation Sections -->
  <section class="section">
    <div class="container">
      <div class="section-header text-center">
        <span class="section-label">INNOVATION</span>
        <h2>Building for Tomorrow</h2>
        <p>From rapid prototyping to launching real-world solutions</p>
      </div>
      
      <div class="innovation-grid">
        <div class="innovation-card">
          <div class="innovation-icon">🧠</div>
          <h3>AI Hackathons</h3>
          <p>Solving real-world problems using Artificial Intelligence. Students work in teams to develop innovative applications.</p>
        </div>
        <div class="innovation-card">
          <div class="innovation-icon">🚀</div>
          <h3>Startup Accelerator</h3>
          <p>Transforming tech ideas into viable businesses through mentorship, product development, and funding readiness.</p>
        </div>
        <div class="innovation-card">
          <div class="innovation-icon">💻</div>
          <h3>Future Tech Lab</h3>
          <p>Exploration of emerging trends like Web3, Quantum Computing, and Sustainable Tech solutions.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- AI & Cyber Incubation Lab Section -->
  <section class="section tech-feature-section">
    <div class="containerWide">
      <div class="cyber-lab-card-tech">
        <div class="card-header">
          <span class="section-label">NEW LAUNCH: MAY 21, 2026</span>
          <h2>AI & Cyber Incubation Lab</h2>
        </div>
        <div class="card-image">
          <Image src={aiCyberLabImage} alt="AI & Cyber Incubation Lab" class="lab-img" />
        </div>
        <div class="card-body">
          <p class="description">
            Dive into the most advanced incubation program for youth. We are building a community 
            of AI agents developers and cybersecurity experts.
          </p>
          <div class="tech-stack-grid">
            <div class="tech-item">
              <span class="tech-icon">🤖</span>
              <div>
                <strong>AI Agent Mastery</strong>
                <p>Build and deploy agents using OpenClaw, Claude, OpenAI, Gemini Studio, Cursor and others.</p>
              </div>
            </div>
            <div class="tech-item">
              <span class="tech-icon">🛡️</span>
              <div>
                <strong>Cybersecurity Lab</strong>
                <p>Practical RED vs BLUE with NHI (non-human identities), data security, regulation & compliance - and sovereign secure AI for autonomous systems.</p>
              </div>
            </div>
          </div>
          <div class="card-actions">
            <a href="/register?eventId=ai-cyber-lab" class="btn btn-primary">Apply for Incubation</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&display=swap');

  /* Two Column Layout */
  .two-col-layout {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 5rem;
    align-items: start;
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 0;
  }

  .content-col h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.8rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }

  .content-col p {
    line-height: 1.9;
    color: var(--text-secondary);
    font-size: 1.05rem;
  }

  .yoga-sutra {
    background: var(--sand);
    padding: 2rem;
    border-left: 3px solid var(--blue);
    border-radius: 0 8px 8px 0;
    margin-top: 2rem;
  }

  .yoga-sutra p {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.3rem;
    color: var(--text-primary);
  }

  /* Feature Box */
  .feature-box {
    background: var(--cream);
    padding: 3rem;
    border-radius: 16px;
    box-shadow: var(--shadow-md);
  }

  .feature-icon {
    font-size: 3rem;
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .feature-box h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    text-align: center;
    margin-bottom: 2rem;
  }

  .limbs-list {
    list-style: none;
    padding: 0;
  }

  .limbs-list li {
    padding: 0.8rem 0;
    padding-left: 1.5rem;
    position: relative;
    color: var(--text-secondary);
  }

  .limbs-list li::before {
    content: '○';
    color: var(--blue);
    position: absolute;
    left: 0;
  }

  /* Innovation Grid */
  .innovation-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 3rem;
  }

  .innovation-card {
    background: white;
    padding: 3rem 2.5rem;
    border-radius: 16px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.03);
    text-align: center;
    border: 1px solid rgba(30, 136, 229, 0.15);
    transition: transform 0.3s ease;
  }

  .innovation-card:hover {
    transform: translateY(-5px);
  }

  .innovation-icon {
    font-size: 3rem;
    margin-bottom: 1.5rem;
  }

  .innovation-card h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .section-header h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.8rem;
    margin-bottom: 1rem;
  }

  @media (max-width: 1024px) {
    .two-col-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .innovation-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .innovation-grid {
      grid-template-columns: 1fr;
    }
    .content-col h2, .section-header h2 {
      font-size: 2.2rem;
    }
  }

  /* AI & Cyber Lab Refined Styles */
  .containerWide {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .tech-feature-section {
    padding: 1rem 0;
    background: #fdfdfd;
  }

  .cyber-lab-card-tech {
    display: grid;
    grid-template-columns: 450px 1fr;
    grid-template-areas: 
      "image header"
      "image body";
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.06);
    border: none;
    max-width: 1250px;
    margin: 1rem auto;
    align-items: center;
  }

  .card-header {
    grid-area: header;
    padding: 1.5rem 2rem 0.25rem;
    text-align: left;
  }

  .cyber-lab-card-tech .card-image {
    grid-area: image;
    width: 450px; /* Slightly smaller square for tech page */
    aspect-ratio: 1 / 1;
    position: relative;
    overflow: hidden;
    background: #f8f9fa;
  }

  .lab-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cyber-lab-card-tech .card-body {
    grid-area: body;
    padding: 0.25rem 2rem 1.5rem;
  }

  .cyber-lab-card-tech h2 {
    font-size: 2.4rem;
    margin-bottom: 0.5rem;
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    color: var(--text-primary);
  }
  
  .cyber-lab-card-tech .section-label {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    color: var(--blue);
    margin-bottom: 0.5rem;
    letter-spacing: 1px;
  }

  .description {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    text-align: left;
  }

  .tech-stack-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .tech-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .tech-icon {
    font-size: 1.5rem;
    background: #f0f7ff;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
  }

  .tech-item strong {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem;
    display: block;
    margin-bottom: 0.2rem;
    color: var(--text-primary);
  }

  .tech-item p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .cyber-lab-card-tech {
      grid-template-columns: 1fr;
      grid-template-areas: 
        "header"
        "image"
        "body";
      max-width: 100%;
      margin: 1rem auto;
    }
    .card-header {
      padding: 2.5rem 1.5rem 1rem;
      text-align: center;
    }
    .cyber-lab-card-tech h2 { 
      font-size: 2rem;
      word-wrap: break-word;
    }
    .cyber-lab-card-tech .card-image {
      width: 100%;
      aspect-ratio: 1 / 1;
    }
    .lab-img {
      object-fit: contain;
      padding: 0.5rem;
    }
    .cyber-lab-card-tech .card-body {
      padding: 2rem 2rem 3rem;
      text-align: center;
    }
    .description { text-align: center; }
  }
</style>

