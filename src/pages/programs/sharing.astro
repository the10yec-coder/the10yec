---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProgramHero from '../../components/ProgramHero.astro';
---

<BaseLayout title="Sharing & Service - 10YEC Youth Excellence Center">
  <ProgramHero 
    title="Community Impact" 
    subtitle="Non-profit initiatives focused on Education & Empowerment. Supporting communities through impactful service projects."
    label="SHARING & SERVICE"
    gradient="linear-gradient(135deg, var(--moss) 0%, #2E7D32 100%)"
  />

  <!-- Overview Section -->
  <section class="section">
    <div class="container">
      <div class="two-col-layout">
        <div class="content-col">
          <h2 id="impact">Our Mission to Serve</h2>
          <p>
            At 10YEC, we believe that true excellence is found in service to others. 
            Through our sharing initiatives, we foster compassion, empathy, and a strong 
            commitment to making a positive difference in local and global communities.
          </p>
          <div class="yoga-sutra">
            <p>"The best way to find yourself is to lose yourself in the service of others."</p>
          </div>
        </div>
        <div class="visual-col">
          <div class="feature-box">
            <div class="feature-icon">🤝</div>
            <h3>Service Areas</h3>
            <ul class="limbs-list">
              <li>Educational Support</li>
              <li>Slum Development Projects</li>
              <li>Slum Education Initiatives</li>
              <li>Rural Empowerment</li>
              <li>Youth Mentorship</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Impact Section -->
  <section class="section">
    <div class="container">
      <div class="section-header text-center">
        <span class="section-label">COMMUNITY</span>
        <h2>Making a Difference</h2>
        <p>Meaningful changes through purposeful action and collaboration</p>
      </div>
      
      <div class="impact-grid">
        <div class="impact-card">
          <div class="impact-icon">🌱</div>
          <h3>Education Support</h3>
          <p>Providing resources and training to underserved primary schools in rural areas to ensure a brighter future for children.</p>
        </div>
        <div class="impact-card">
          <div class="impact-icon">🌟</div>
          <h3>Youth Mentorship</h3>
          <p>Connecting experienced leaders with young individuals to guide them in their journey towards holistic excellence.</p>
        </div>
        <div class="impact-card">
          <div class="impact-icon">🌍</div>
          <h3>Global Outreach</h3>
          <p>Partnering with organizations to support sustainable development and social justice initiatives worldwide.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&display=swap');

  /* Two Column Layout */
  .two-col-layout {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 5rem;
    align-items: start;
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 0;
  }

  .content-col h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.8rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }

  .content-col p {
    line-height: 1.9;
    color: var(--text-secondary);
    font-size: 1.05rem;
  }

  .yoga-sutra {
    background: var(--sand);
    padding: 2rem;
    border-left: 3px solid var(--moss);
    border-radius: 0 8px 8px 0;
    margin-top: 2rem;
  }

  .yoga-sutra p {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.3rem;
    color: var(--text-primary);
  }

  /* Feature Box */
  .feature-box {
    background: var(--cream);
    padding: 3rem;
    border-radius: 16px;
    box-shadow: var(--shadow-md);
  }

  .feature-icon {
    font-size: 3rem;
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .feature-box h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    text-align: center;
    margin-bottom: 2rem;
  }

  .limbs-list {
    list-style: none;
    padding: 0;
  }

  .limbs-list li {
    padding: 0.8rem 0;
    padding-left: 1.5rem;
    position: relative;
    color: var(--text-secondary);
  }

  .limbs-list li::before {
    content: '○';
    color: var(--moss);
    position: absolute;
    left: 0;
  }

  /* Impact Grid */
  .impact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 3rem;
  }

  .impact-card {
    background: white;
    padding: 3rem 2.5rem;
    border-radius: 16px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.03);
    text-align: center;
    border: 1px solid rgba(46, 125, 50, 0.15);
    transition: transform 0.3s ease;
  }

  .impact-card:hover {
    transform: translateY(-5px);
  }

  .impact-icon {
    font-size: 3rem;
    margin-bottom: 1.5rem;
  }

  .impact-card h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .section-header h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.8rem;
    margin-bottom: 1rem;
  }

  @media (max-width: 1024px) {
    .two-col-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .impact-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .impact-grid {
      grid-template-columns: 1fr;
    }
    .content-col h2, .section-header h2 {
      font-size: 2.2rem;
    }
  }
</style>
